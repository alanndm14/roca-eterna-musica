VITE_FIREBASE_API_KEY=tu_api_key_web
VITE_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu-proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_FIREBASE_VAPID_KEY=
VITE_FIREBASE_APPCHECK_SITE_KEY=

# Solo local. No configurar en GitHub Pages ni Vercel de produccion.
VITE_FIREBASE_APPCHECK_DEBUG_TOKEN=

# Correos que pueden crear el primer usuario admin.
# Usa comas para varios correos.
VITE_INITIAL_ADMIN_EMAILS=tu-correo@gmail.com

# El modo demo solo debe activarse localmente o cuando lo decidas explicitamente.
VITE_ENABLE_DEMO_MODE=false

# Solo para probar localmente un build como si estuviera en dominio propio.
# En GitHub Actions se usa el secreto PAGES_CUSTOM_DOMAIN.
VITE_CUSTOM_DOMAIN=false

# Opcional: protege manualmente el endpoint de recordatorios programados.
# Si no existe, Vercel Cron puede ejecutarlo igual.
CRON_SECRET=
