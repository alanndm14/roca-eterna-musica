rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function authorizedEmailDoc() {
      return get(/databases/$(database)/documents/authorizedEmails/$(request.auth.token.email));
    }

    function legacyAllowedEmailDoc() {
      return get(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email));
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasAuthorizedEmailDoc() {
      return exists(/databases/$(database)/documents/authorizedEmails/$(request.auth.token.email))
        && authorizedEmailDoc().data.active == true;
    }

    function hasLegacyAllowedEmailDoc() {
      return exists(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email))
        && legacyAllowedEmailDoc().data.active == true;
    }

    function isAuthorized() {
      return signedIn()
        && (
          (
            hasUserDoc()
            && userDoc().data.active == true
            && userDoc().data.email == request.auth.token.email
          )
          || hasAuthorizedEmailDoc()
          || hasLegacyAllowedEmailDoc()
        );
    }

    function role() {
      return hasUserDoc()
          ? userDoc().data.role
          : hasAuthorizedEmailDoc()
            ? authorizedEmailDoc().data.role
            : legacyAllowedEmailDoc().data.role;
    }

    function isAdmin() {
      return isAuthorized() && role() in ["admin", "administrator", "administrador"];
    }

    function rolesMatch(leftRole, rightRole) {
      return leftRole == rightRole
        || (
          leftRole in ["admin", "administrator", "administrador"]
          && rightRole in ["admin", "administrator", "administrador"]
        );
    }

    function isFullAdmin() {
      return isAdmin();
    }

    function isActivityOwner() {
      return signedIn() && request.auth.token.email == "liquea45@gmail.com";
    }

    function isEditor() {
      return isAuthorized() && (isAdmin() || role() == "editor");
    }

    function viewerType() {
      return hasUserDoc()
          ? userDoc().data.get("viewerType", "")
          : hasAuthorizedEmailDoc()
            ? authorizedEmailDoc().data.get("viewerType", "")
            : legacyAllowedEmailDoc().data.get("viewerType", "");
    }

    function canUseVocalPractice() {
      return isAuthorized()
        && (
          isAdmin()
          || role() == "editor"
          || viewerType() in ["corista", "musico"]
        );
    }

    function canManageVocalPractice() {
      return isAuthorized()
        && (
          isAdmin()
          || role() == "editor"
        );
    }

    function validShortString(value, maxSize) {
      return value is string && value.size() > 0 && value.size() <= maxSize;
    }

    function validOptionalString(value, maxSize) {
      return value == null || (value is string && value.size() <= maxSize);
    }

    function validOptionalList(value, maxSize) {
      return value == null || (value is list && value.size() <= maxSize);
    }

    function validActivityData() {
      return request.resource.data.keys().hasAll(["uid", "email", "eventType", "section", "route", "sessionId", "clientTimestamp"])
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.eventType in ["section_view", "click", "disconnect"]
        && validOptionalString(request.resource.data.get("section", null), 80)
        && validOptionalString(request.resource.data.get("route", null), 240)
        && validOptionalString(request.resource.data.get("targetLabel", null), 180)
        && validOptionalString(request.resource.data.get("targetTag", null), 40)
        && validOptionalString(request.resource.data.get("sessionId", null), 80)
        && (
          request.resource.data.get("durationMs", 0) is int
          || request.resource.data.get("durationMs", 0) is float
        )
        && request.resource.data.get("durationMs", 0) >= 0
        && request.resource.data.get("durationMs", 0) <= 8 * 60 * 60 * 1000;
    }

    function validSongCoreData() {
      return request.resource.data.keys().hasAll(["title"])
        && validShortString(request.resource.data.title, 160)
        && validOptionalString(request.resource.data.get("mainKey", null), 24)
        && validOptionalString(request.resource.data.get("keyWithCapo", null), 24)
        && validOptionalString(request.resource.data.get("originalKey", null), 24)
        && (
          request.resource.data.get("originalBpm", null) == null
          || (
            request.resource.data.get("originalBpm", null) is int
            && request.resource.data.get("originalBpm", null) >= 0
            && request.resource.data.get("originalBpm", null) <= 240
          )
        )
        && (
          request.resource.data.get("timeSignature", null) == null
          || request.resource.data.get("timeSignature", null) in ["", "2/4", "3/4", "4/4", "6/8"]
        )
        && validOptionalString(request.resource.data.get("originalEntryNote", null), 16)
        && (
          request.resource.data.get("churchBpm", null) == null
          || (
            request.resource.data.get("churchBpm", null) is int
            && request.resource.data.get("churchBpm", null) >= 0
            && request.resource.data.get("churchBpm", null) <= 240
          )
        )
        && (
          request.resource.data.get("churchTimeSignature", null) == null
          || request.resource.data.get("churchTimeSignature", null) in ["", "2/4", "3/4", "4/4", "6/8"]
        )
        && validOptionalString(request.resource.data.get("churchEntryNote", null), 16)
        && validOptionalString(request.resource.data.get("mainTheme", null), 80)
        && validOptionalString(request.resource.data.get("category", null), 80)
        && validOptionalString(request.resource.data.get("localPdfPath", null), 500)
        && validOptionalString(request.resource.data.get("drivePdfUrl", null), 1000)
        && validOptionalString(request.resource.data.get("youtubeUrl", null), 1000)
        && validOptionalString(request.resource.data.get("spotifyUrl", null), 1000)
        && validOptionalList(request.resource.data.get("tags", null), 80)
        && validOptionalList(request.resource.data.get("otherThemes", null), 40)
        && validOptionalList(request.resource.data.get("lyricsSections", null), 200);
    }

    function validSongCoverData() {
      return validOptionalString(request.resource.data.get("coverImagePath", null), 500)
        && validOptionalString(request.resource.data.get("coverFileName", null), 160)
        && (
          request.resource.data.get("coverVersion", null) == null
          || request.resource.data.get("coverVersion", null) is int
        )
        && (
          request.resource.data.get("coverEnabled", null) == null
          || request.resource.data.get("coverEnabled", null) is bool
        )
        && (
          request.resource.data.get("coverPosition", null) == null
          || request.resource.data.get("coverPosition", null) in ["center", "top", "bottom", "left", "right"]
        )
        && (
          request.resource.data.get("coverIntensity", null) == null
          || request.resource.data.get("coverIntensity", null) in ["subtle", "medium"]
        )
        && (
          request.resource.data.get("coverBackgroundMode", null) == null
          || request.resource.data.get("coverBackgroundMode", null) in ["image", "color"]
        )
        && (
          request.resource.data.get("coverBackgroundOpacity", null) == null
          || (
            request.resource.data.get("coverBackgroundOpacity", null) is int
            && request.resource.data.get("coverBackgroundOpacity", null) >= 0
            && request.resource.data.get("coverBackgroundOpacity", null) <= 100
          )
        )
        && (
          request.resource.data.get("coverAccentColor", null) == null
          || (
            request.resource.data.get("coverAccentColor", null) is string
            && request.resource.data.get("coverAccentColor", null).matches("^#[0-9a-fA-F]{6}$")
          )
        )
        && validOptionalString(request.resource.data.get("coverUpdatedBy", null), 160)
        && validOptionalString(request.resource.data.get("coverUpdatedByName", null), 200)
        && (
          request.resource.data.get("coverUpdatedAt", null) == null
          || request.resource.data.get("coverUpdatedAt", null) is timestamp
        );
    }

    function songCoverFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasAny([
        "coverImagePath",
        "coverFileName",
        "coverVersion",
        "coverEnabled",
        "coverPosition",
        "coverIntensity",
        "coverBackgroundMode",
        "coverBackgroundOpacity",
        "coverAccentColor",
        "coverUpdatedAt",
        "coverUpdatedBy",
        "coverUpdatedByName"
      ]);
    }

    function songCoverOnlyFieldsChanged() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
        "coverImagePath",
        "coverFileName",
        "coverVersion",
        "coverEnabled",
        "coverPosition",
        "coverIntensity",
        "coverBackgroundMode",
        "coverBackgroundOpacity",
        "coverAccentColor",
        "coverUpdatedAt",
        "coverUpdatedBy",
        "coverUpdatedByName",
        "updatedAt"
      ]);
    }

    function validScheduleSongs() {
      return request.resource.data.get("songs", null) == null
        || (
          request.resource.data.get("songs", null) is list
          && request.resource.data.get("songs", null).size() <= 80
        );
    }

    function validPracticeGuideData() {
      return request.resource.data.keys().hasAll([
          "title",
          "sectionType",
          "voicePart",
          "storagePath",
          "fileName",
          "mimeType",
          "sizeBytes",
          "durationSeconds",
          "order",
          "enabled",
          "createdBy",
          "updatedBy"
        ])
        && validShortString(request.resource.data.title, 160)
        && request.resource.data.sectionType in ["full", "verse", "prechorus", "chorus", "bridge", "final-chorus", "intro", "outro", "other"]
        && request.resource.data.voicePart in ["all", "melody", "soprano", "alto", "tenor", "second", "other"]
        && validOptionalString(request.resource.data.get("customSectionName", null), 120)
        && validOptionalString(request.resource.data.get("key", null), 24)
        && request.resource.data.get("bpm", 0) is number
        && request.resource.data.get("bpm", 0) >= 0
        && request.resource.data.get("bpm", 0) <= 240
        && request.resource.data.get("timeSignature", "4/4") in ["2/4", "3/4", "4/4", "6/8"]
        && validOptionalString(request.resource.data.get("entryNote", null), 16)
        && validOptionalString(request.resource.data.get("notes", null), 1000)
        && validShortString(request.resource.data.storagePath, 500)
        && request.resource.data.storagePath.matches("^public/practice-guides/[A-Za-z0-9._/-]+$")
        && validOptionalString(request.resource.data.get("audioUrl", null), 700)
        && validShortString(request.resource.data.fileName, 240)
        && request.resource.data.mimeType in ["audio/mpeg", "audio/mp4", "audio/x-m4a", "audio/wav", "audio/ogg"]
        && request.resource.data.sizeBytes is int
        && request.resource.data.sizeBytes > 0
        && request.resource.data.sizeBytes <= 3 * 1024 * 1024
        && request.resource.data.durationSeconds is number
        && request.resource.data.order is int
        && request.resource.data.enabled is bool
        && validShortString(request.resource.data.createdBy, 160)
        && validShortString(request.resource.data.updatedBy, 160);
    }

    function practiceSongFieldsAreEmpty() {
      return request.resource.data.get("originalKey", "") == ""
        && request.resource.data.get("originalBpm", 0) == 0
        && request.resource.data.get("timeSignature", "") == ""
        && request.resource.data.get("originalEntryNote", "") == ""
        && request.resource.data.get("churchBpm", 0) == 0
        && request.resource.data.get("churchTimeSignature", "") == ""
        && request.resource.data.get("churchEntryNote", "") == "";
    }

    function practiceSongFieldsAreUnchanged() {
      return request.resource.data.get("originalKey", "") == resource.data.get("originalKey", "")
        && request.resource.data.get("originalBpm", 0) == resource.data.get("originalBpm", resource.data.get("tempo", 0))
        && request.resource.data.get("timeSignature", "") == resource.data.get("timeSignature", "")
        && request.resource.data.get("originalEntryNote", "") == resource.data.get("originalEntryNote", "")
        && request.resource.data.get("churchBpm", 0) == resource.data.get("churchBpm", 0)
        && request.resource.data.get("churchTimeSignature", "") == resource.data.get("churchTimeSignature", "")
        && request.resource.data.get("churchEntryNote", "") == resource.data.get("churchEntryNote", "");
    }

    function validScheduleData() {
      return request.resource.data.keys().hasAll(["date"])
        && validShortString(request.resource.data.date, 20)
        && validOptionalString(request.resource.data.get("time", null), 20)
        && validOptionalString(request.resource.data.get("type", null), 120)
        && validOptionalString(request.resource.data.get("serviceType", null), 120)
        && validOptionalString(request.resource.data.get("serviceLabel", null), 160)
        && validOptionalString(request.resource.data.get("leader", null), 160)
        && validOptionalString(request.resource.data.get("status", null), 60)
        && validOptionalString(request.resource.data.get("generalNotes", null), 4000)
        && validScheduleSongs();
    }

    function validPlannedNewSongData() {
      return request.resource.data.keys().hasAll([
          "songId",
          "songTitle",
          "plannedDate",
          "serviceType",
          "status",
          "notes",
          "createdBy",
          "createdAt",
          "updatedAt",
          "introducedAt"
        ])
        && (request.resource.data.songId == null || validShortString(request.resource.data.songId, 200))
        && validShortString(request.resource.data.songTitle, 200)
        && validShortString(request.resource.data.plannedDate, 20)
        && request.resource.data.serviceType in ["domingo_am", "domingo_pm", "miercoles", "especial", "otro"]
        && request.resource.data.status in ["planeado", "listo", "estrenado", "pospuesto"]
        && validOptionalString(request.resource.data.notes, 2000)
        && request.resource.data.createdBy is string
        && request.resource.data.createdBy.size() > 0
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (request.resource.data.introducedAt == null || request.resource.data.introducedAt is timestamp);
    }

    function validThemeData() {
      return request.resource.data.keys().hasAll(["name"])
        && validShortString(request.resource.data.name, 80)
        && (request.resource.data.get("active", null) == null || request.resource.data.get("active", null) is bool)
        && (request.resource.data.get("ignored", null) == null || request.resource.data.get("ignored", null) is bool);
    }

    function validLoginVerseData() {
      return request.resource.data.keys().hasAll(["text", "reference", "active"])
        && validShortString(request.resource.data.text, 1200)
        && validShortString(request.resource.data.reference, 120)
        && validOptionalString(request.resource.data.get("translation", null), 80)
        && request.resource.data.active is bool;
    }

    function validDailyVerseOverrideData(dateKey) {
      return request.resource.data.keys().hasAll(["date", "verseId"])
        && request.resource.data.date == dateKey
        && validShortString(request.resource.data.verseId, 200);
    }

    function validNotificationData() {
      return request.resource.data.keys().hasAll(["type", "title", "message", "createdByUid", "createdByEmail"])
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByEmail == request.auth.token.email
        && request.resource.data.type in ["new_song", "new_schedule", "updated_schedule", "other"]
        && validShortString(request.resource.data.title, 160)
        && validOptionalString(request.resource.data.get("message", null), 1000)
        && validOptionalString(request.resource.data.get("entityType", null), 40)
        && validOptionalString(request.resource.data.get("entityId", null), 160)
        && validOptionalString(request.resource.data.get("scheduleId", null), 160)
        && validOptionalString(request.resource.data.get("songId", null), 160)
        && validOptionalList(request.resource.data.get("targetRoles", null), 5)
        && validOptionalList(request.resource.data.get("targetUsers", null), 200)
        && validOptionalList(request.resource.data.get("targetViewerTypes", null), 5);
    }

    function validAuditData() {
      return request.resource.data.performedByUid == request.auth.uid
        && request.resource.data.performedByEmail == request.auth.token.email
        && request.resource.data.actionType is string
        && request.resource.data.actionType.size() <= 80
        && request.resource.data.entityType is string
        && request.resource.data.entityType.size() <= 80
        && validOptionalString(request.resource.data.get("entityId", null), 200)
        && validOptionalString(request.resource.data.get("entityName", null), 300)
        && validOptionalString(request.resource.data.get("summary", null), 1000);
    }

    function canWriteOwnDeviceToken(userId) {
      return signedIn()
        && request.auth.uid == userId
        && (
          (
            hasUserDoc()
            && userDoc().data.active == true
            && userDoc().data.email == request.auth.token.email
          )
          || hasAuthorizedEmailDoc()
          || hasLegacyAllowedEmailDoc()
        );
    }

    match /users/{userId} {
      allow read: if isAuthorized();
      allow create: if signedIn()
        && request.auth.uid == userId
        && (hasAuthorizedEmailDoc() || hasLegacyAllowedEmailDoc())
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.active == true
        && request.resource.data.role in ["admin", "administrator", "administrador", "editor", "viewer"]
        && (
          request.resource.data.role != "viewer"
          || request.resource.data.get("viewerType", "corista") in ["corista", "musico", "medios"]
        )
        && (
          (hasAuthorizedEmailDoc() && rolesMatch(request.resource.data.role, authorizedEmailDoc().data.role))
          || (hasLegacyAllowedEmailDoc() && rolesMatch(request.resource.data.role, legacyAllowedEmailDoc().data.role))
        );
      allow update: if isAdmin()
        || (
          isAuthorized()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "lastLogin",
            "lastLoginAt",
            "lastSeenAt",
            "preferredDisplayName",
            "themeMode",
            "accentColor",
            "blueGrayColor",
            "sidebarCollapsed",
            "onboardingCompleted",
            "onboardingCompletedAt",
            "dismissedPushPromptByUser",
            "wantsPushNotifications",
            "pushNotificationsEnabled",
            "pushNotificationsEnabledAt",
            "lastActivityAt",
            "lastActivitySection",
            "lastDisconnectedAt",
            "activityTotalMs",
            "preferencesUpdatedAt"
          ])
        );
      allow delete: if isAdmin();

      match /fcmTokens/{tokenId} {
        allow read: if isAdmin() || canWriteOwnDeviceToken(userId);
        allow create, update, delete: if canWriteOwnDeviceToken(userId);
      }
    }

    match /authorizedEmails/{email} {
      allow get: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow list, create, update, delete: if isAdmin();
    }

    match /userActivity/{activityId} {
      allow read: if isActivityOwner();
      allow create: if isAuthorized() && validActivityData();
      allow update, delete: if false;
    }

    match /allowedEmails/{email} {
      allow get: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow list, create, update, delete: if isAdmin();
    }

    match /songs/{songId} {
      allow read: if isAuthorized();
      allow create: if isEditor()
        && validSongCoreData()
        && validSongCoverData()
        && (canManageVocalPractice() || practiceSongFieldsAreEmpty());
      allow update: if isEditor()
        && (
          (
            songCoverOnlyFieldsChanged()
            && validSongCoverData()
          )
          || (
            validSongCoreData()
            && (!songCoverFieldsChanged() || validSongCoverData())
            && (canManageVocalPractice() || practiceSongFieldsAreUnchanged())
          )
        );
      allow delete: if isFullAdmin();

      match /practiceGuides/{guideId} {
        allow read: if canUseVocalPractice();
        allow create: if canManageVocalPractice()
          && validPracticeGuideData()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.updatedBy == request.auth.uid;
        allow update: if canManageVocalPractice()
          && validPracticeGuideData()
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.updatedBy == request.auth.uid;
        allow delete: if canManageVocalPractice();
      }
    }

    match /schedules/{scheduleId} {
      allow read: if isAuthorized();
      allow create: if isEditor() && validScheduleData();
      allow update: if isEditor() && validScheduleData();
      allow delete: if isFullAdmin();
    }

    match /plannedNewSongs/{plannedNewSongId} {
      allow read: if isAuthorized();
      allow create: if isEditor()
        && validPlannedNewSongData()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isEditor()
        && validPlannedNewSongData()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isFullAdmin();
    }

    match /themes/{themeId} {
      allow read: if isAuthorized();
      allow create, update: if isEditor() && validThemeData();
      allow delete: if isFullAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthorized();
      allow write: if isFullAdmin();
    }

    match /loginVerses/{verseId} {
      allow read: if true;
      allow create, update: if isFullAdmin() && validLoginVerseData();
      allow delete: if isFullAdmin();
    }

    match /dailyVerseOverrides/{dateKey} {
      allow read: if true;
      allow create, update: if isFullAdmin() && validDailyVerseOverrideData(dateKey);
      allow delete: if isFullAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if validAuditData() && (isAdmin() || isEditor());
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthorized();
      allow create: if isEditor() && validNotificationData();
      allow update: if isAuthorized()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readBy"]);
      allow update: if isEditor()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["active", "deleted", "relatedEntityDeleted", "deletedAt", "readBy"]);
      allow delete: if isFullAdmin();

      match /reads/{userId} {
        allow read: if isAdmin() || (isAuthorized() && request.auth.uid == userId);
        allow create, update: if isAuthorized() && request.auth.uid == userId;
        allow delete: if isFullAdmin();
      }
    }
  }
}
