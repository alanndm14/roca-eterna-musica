rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function bootstrapAdminEmails() {
      // Cambia esta lista antes de publicar reglas en producción.
      return ["liquea45@gmail.com"];
    }

    function isBootstrapAdmin() {
      return signedIn() && request.auth.token.email in bootstrapAdminEmails();
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function authorizedEmailDoc() {
      return get(/databases/$(database)/documents/authorizedEmails/$(request.auth.token.email));
    }

    function legacyAllowedEmailDoc() {
      return get(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email));
    }

    function hasUserDoc() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasAuthorizedEmailDoc() {
      return exists(/databases/$(database)/documents/authorizedEmails/$(request.auth.token.email))
        && authorizedEmailDoc().data.active == true;
    }

    function hasLegacyAllowedEmailDoc() {
      return exists(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email))
        && legacyAllowedEmailDoc().data.active == true;
    }

    function isAuthorized() {
      return signedIn()
        && (
          isBootstrapAdmin()
          || (
            hasUserDoc()
            && userDoc().data.active == true
            && userDoc().data.email == request.auth.token.email
          )
          || hasAuthorizedEmailDoc()
          || hasLegacyAllowedEmailDoc()
        );
    }

    function role() {
      return isBootstrapAdmin()
        ? "admin"
        : hasUserDoc()
          ? userDoc().data.role
          : hasAuthorizedEmailDoc()
            ? authorizedEmailDoc().data.role
            : legacyAllowedEmailDoc().data.role;
    }

    function isAdmin() {
      return isAuthorized() && role() == "admin";
    }

    function isEditor() {
      return isAuthorized() && (role() == "admin" || role() == "editor");
    }

    function viewerType() {
      return isBootstrapAdmin()
        ? ""
        : hasUserDoc()
          ? userDoc().data.get("viewerType", "")
          : hasAuthorizedEmailDoc()
            ? authorizedEmailDoc().data.get("viewerType", "")
            : legacyAllowedEmailDoc().data.get("viewerType", "");
    }

    function isMediaViewer() {
      return isAuthorized() && role() == "viewer" && viewerType() == "medios";
    }

    function validShortString(value, maxSize) {
      return value is string && value.size() > 0 && value.size() <= maxSize;
    }

    function validOptionalString(value, maxSize) {
      return value == null || (value is string && value.size() <= maxSize);
    }

    function validOptionalList(value, maxSize) {
      return value == null || (value is list && value.size() <= maxSize);
    }

    function validSongData() {
      return request.resource.data.keys().hasAll(["title"])
        && validShortString(request.resource.data.title, 160)
        && validOptionalString(request.resource.data.get("mainKey", null), 24)
        && validOptionalString(request.resource.data.get("keyWithCapo", null), 24)
        && validOptionalString(request.resource.data.get("mainTheme", null), 80)
        && validOptionalString(request.resource.data.get("category", null), 80)
        && validOptionalString(request.resource.data.get("localPdfPath", null), 500)
        && validOptionalString(request.resource.data.get("drivePdfUrl", null), 1000)
        && validOptionalString(request.resource.data.get("youtubeUrl", null), 1000)
        && validOptionalString(request.resource.data.get("spotifyUrl", null), 1000)
        && validOptionalList(request.resource.data.get("tags", null), 80)
        && validOptionalList(request.resource.data.get("otherThemes", null), 40)
        && validOptionalList(request.resource.data.get("lyricsSections", null), 200);
    }

    function validScheduleSongs() {
      return request.resource.data.get("songs", null) == null
        || (
          request.resource.data.get("songs", null) is list
          && request.resource.data.get("songs", null).size() <= 80
        );
    }

    function validScheduleData() {
      return request.resource.data.keys().hasAll(["date"])
        && validShortString(request.resource.data.date, 20)
        && validOptionalString(request.resource.data.get("time", null), 20)
        && validOptionalString(request.resource.data.get("type", null), 120)
        && validOptionalString(request.resource.data.get("serviceType", null), 120)
        && validOptionalString(request.resource.data.get("serviceLabel", null), 160)
        && validOptionalString(request.resource.data.get("leader", null), 160)
        && validOptionalString(request.resource.data.get("status", null), 60)
        && validOptionalString(request.resource.data.get("generalNotes", null), 4000)
        && validOptionalString(request.resource.data.get("slidesUrl", null), 1000)
        && validScheduleSongs();
    }

    function validPlannedNewSongData() {
      return request.resource.data.keys().hasAll([
          "songId",
          "songTitle",
          "plannedDate",
          "serviceType",
          "status",
          "notes",
          "createdBy",
          "createdAt",
          "updatedAt",
          "introducedAt"
        ])
        && (request.resource.data.songId == null || validShortString(request.resource.data.songId, 200))
        && validShortString(request.resource.data.songTitle, 200)
        && validShortString(request.resource.data.plannedDate, 20)
        && request.resource.data.serviceType in ["domingo_am", "domingo_pm", "miercoles", "especial", "otro"]
        && request.resource.data.status in ["planeado", "listo", "estrenado", "pospuesto"]
        && validOptionalString(request.resource.data.notes, 2000)
        && request.resource.data.createdBy is string
        && request.resource.data.createdBy.size() > 0
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && (request.resource.data.introducedAt == null || request.resource.data.introducedAt is timestamp);
    }

    function validThemeData() {
      return request.resource.data.keys().hasAll(["name"])
        && validShortString(request.resource.data.name, 80)
        && (request.resource.data.get("active", null) == null || request.resource.data.get("active", null) is bool)
        && (request.resource.data.get("ignored", null) == null || request.resource.data.get("ignored", null) is bool);
    }

    function validLoginVerseData() {
      return request.resource.data.keys().hasAll(["text", "reference", "active"])
        && validShortString(request.resource.data.text, 1200)
        && validShortString(request.resource.data.reference, 120)
        && validOptionalString(request.resource.data.get("translation", null), 80)
        && request.resource.data.active is bool;
    }

    function validDailyVerseOverrideData(dateKey) {
      return request.resource.data.keys().hasAll(["date", "verseId"])
        && request.resource.data.date == dateKey
        && validShortString(request.resource.data.verseId, 200);
    }

    function validNotificationData() {
      return request.resource.data.keys().hasAll(["type", "title", "message", "createdByUid", "createdByEmail"])
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.createdByEmail == request.auth.token.email
        && request.resource.data.type in ["new_song", "new_schedule", "updated_schedule", "other"]
        && validShortString(request.resource.data.title, 160)
        && validOptionalString(request.resource.data.get("message", null), 1000)
        && validOptionalString(request.resource.data.get("entityType", null), 40)
        && validOptionalString(request.resource.data.get("entityId", null), 160)
        && validOptionalString(request.resource.data.get("scheduleId", null), 160)
        && validOptionalString(request.resource.data.get("songId", null), 160)
        && validOptionalList(request.resource.data.get("targetRoles", null), 5)
        && validOptionalList(request.resource.data.get("targetUsers", null), 200)
        && validOptionalList(request.resource.data.get("targetViewerTypes", null), 5);
    }

    function validMediaSlidesNotificationData() {
      return validNotificationData()
        && request.resource.data.type == "other"
        && request.resource.data.get("entityType", "") == "schedule"
        && validShortString(request.resource.data.get("scheduleId", ""), 160)
        && request.resource.data.get("targetRoles", []) == ["admin", "viewer"]
        && request.resource.data.get("targetViewerTypes", []) == ["medios"];
    }

    function validAuditData() {
      return request.resource.data.performedByUid == request.auth.uid
        && request.resource.data.performedByEmail == request.auth.token.email
        && request.resource.data.actionType is string
        && request.resource.data.actionType.size() <= 80
        && request.resource.data.entityType is string
        && request.resource.data.entityType.size() <= 80
        && validOptionalString(request.resource.data.get("entityId", null), 200)
        && validOptionalString(request.resource.data.get("entityName", null), 300)
        && validOptionalString(request.resource.data.get("summary", null), 1000);
    }

    function canWriteOwnDeviceToken(userId) {
      return signedIn()
        && request.auth.uid == userId
        && (
          isBootstrapAdmin()
          || (
            hasUserDoc()
            && userDoc().data.active == true
            && userDoc().data.email == request.auth.token.email
          )
          || hasAuthorizedEmailDoc()
          || hasLegacyAllowedEmailDoc()
        );
    }

    match /users/{userId} {
      allow read: if isAuthorized();
      allow create: if signedIn()
        && request.auth.uid == userId
        && (isBootstrapAdmin() || hasAuthorizedEmailDoc() || hasLegacyAllowedEmailDoc())
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.active == true
        && request.resource.data.role in ["admin", "editor", "viewer"]
        && (
          request.resource.data.role != "viewer"
          || request.resource.data.get("viewerType", "corista") in ["corista", "musico", "medios"]
        )
        && (
          isBootstrapAdmin()
          || (hasAuthorizedEmailDoc() && request.resource.data.role == authorizedEmailDoc().data.role)
          || (hasLegacyAllowedEmailDoc() && request.resource.data.role == legacyAllowedEmailDoc().data.role)
        );
      allow update: if isAdmin()
        || (
          isAuthorized()
          && request.auth.uid == userId
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "lastLogin",
            "lastLoginAt",
            "lastSeenAt",
            "preferredDisplayName",
            "themeMode",
            "accentColor",
            "blueGrayColor",
            "sidebarCollapsed",
            "onboardingCompleted",
            "onboardingCompletedAt",
            "dismissedPushPromptByUser",
            "preferencesUpdatedAt"
          ])
        );
      allow delete: if isAdmin();

      match /fcmTokens/{tokenId} {
        allow read: if isAdmin() || canWriteOwnDeviceToken(userId);
        allow create, update, delete: if canWriteOwnDeviceToken(userId);
      }
    }

    match /authorizedEmails/{email} {
      allow get: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow list, create, update, delete: if isAdmin();
    }

    match /allowedEmails/{email} {
      allow get: if isAdmin() || (signedIn() && request.auth.token.email == email);
      allow list, create, update, delete: if isAdmin();
    }

    match /songs/{songId} {
      allow read: if isAuthorized();
      allow create, update: if isEditor() && validSongData();
      allow delete: if isAdmin();
    }

    match /schedules/{scheduleId} {
      allow read: if isAuthorized();
      allow create: if isEditor() && validScheduleData();
      allow update: if (isEditor() && validScheduleData())
        || (
          isMediaViewer()
          && validScheduleData()
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "slidesUrl",
            "slidesUpdatedAt",
            "slidesUpdatedByUid",
            "slidesUpdatedByName"
          ])
          && request.resource.data.get("slidesUpdatedByUid", "") == request.auth.uid
          && validOptionalString(request.resource.data.get("slidesUpdatedByName", null), 160)
        );
      allow delete: if isAdmin();
    }

    match /plannedNewSongs/{plannedNewSongId} {
      allow read: if isAuthorized();
      allow create: if isEditor()
        && validPlannedNewSongData()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isEditor()
        && validPlannedNewSongData()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /themes/{themeId} {
      allow read: if isAuthorized();
      allow create, update: if isEditor() && validThemeData();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthorized();
      allow write: if isAdmin();
    }

    match /loginVerses/{verseId} {
      allow read: if true;
      allow create, update: if isAdmin() && validLoginVerseData();
      allow delete: if isAdmin();
    }

    match /dailyVerseOverrides/{dateKey} {
      allow read: if true;
      allow create, update: if isAdmin() && validDailyVerseOverrideData(dateKey);
      allow delete: if isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if validAuditData()
        && (isEditor() || (isMediaViewer() && request.resource.data.entityType == "schedule_slides"));
      allow update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if isAuthorized();
      allow create: if (isEditor() && validNotificationData())
        || (isMediaViewer() && validMediaSlidesNotificationData());
      allow update: if isAuthorized()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["readBy"]);
      allow update: if isEditor()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["active", "deleted", "relatedEntityDeleted", "deletedAt", "readBy"]);
      allow delete: if isAdmin();

      match /reads/{userId} {
        allow read: if isAdmin() || (isAuthorized() && request.auth.uid == userId);
        allow create, update: if isAuthorized() && request.auth.uid == userId;
        allow delete: if isAdmin();
      }
    }
  }
}
